<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!-- So a corrupted-state exception (e.g. a wrong DComp vtable slot) is catchable and degrades
         to the WPF fallback instead of killing the tray app. -->
    <legacyCorruptedStateExceptionsPolicy enabled="true" />
  </runtime>
</configuration>
